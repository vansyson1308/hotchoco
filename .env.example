# ─── Telegram Bot ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=replace-me
OWNER_TELEGRAM_ID=123456789

# ─── Google Sheets (Primary Database) ───────────────────────────
# The spreadsheet ID from your VJ-Pos Google Sheets URL
GOOGLE_SHEETS_SPREADSHEET_ID=replace-me
# Base64-encoded Google Service Account credentials JSON
GOOGLE_SERVICE_ACCOUNT_JSON=

# ─── n8n Configuration ──────────────────────────────────────────
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=replace-with-32-char-secret
GENERIC_TIMEZONE=Asia/Ho_Chi_Minh

# ─── POS API ────────────────────────────────────────────────────
POS_API_PORT=3099
POS_API_KEY=replace-with-your-api-key
CORS_ORIGIN=

# ─── Redis (for mutex locks and caching) ────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Logging ────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development

# ─── Setup ──────────────────────────────────────────────────────
SETUP_SECRET=change-this-secret
ONBOARDING_ENABLED=true
GATING_ENFORCE=true
PLATFORM_CORE_V2=true

# ─── Optional: FX Provider ──────────────────────────────────────
FX_PROVIDER=none
FX_API_KEY=

{
  "name": "hotchoco",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run tests --exclude tests/integration/** --exclude tests/e2e/**",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "pos-api:start": "node services/pos-api/src/server.ts",
    "setup-sheets": "node tools/setup-sheets.ts",
    "loadtest:50shops": "node tools/loadtest/run_loadtest_50shops.ts",
    "smoke": "node tools/smoke_check.js",
    "doctor": "node tools/doctor.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"services/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"services/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.10",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.0.8"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "nanoid": "^5.1.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  }
}
